APP_NAME=FamilyOps AI
DEBUG=false
ENVIRONMENT=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Gemini (recommended)
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=models/embedding-001

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional reranking
ENABLE_CROSS_ENCODER_RERANK=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_TOP_N=10

# Privacy
ENABLE_PII_REDACTION=true
ENABLE_STRICT_PII_REDACTION=false
REDACTION_AUDIT_LOG_PATH=

# Redis (optional for Celery tasks)
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=change-me-in-production
API_BEARER_TOKEN=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Email (IMAP)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=your@gmail.com
EMAIL_PASSWORD=app-password
IMPORTANT_EMAIL_KEYWORDS=urgent,action required,reply required,invoice,payment,deadline,permission slip,form,rsvp,conference,pickup,drop off
IMPORTANT_EMAIL_SENDERS=
IMPORTANT_EMAIL_SENDER_DOMAINS=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web search supports duckduckgo, tavily, or auto.
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_TAVILY_API_KEY=
WEB_SEARCH_TAVILY_SEARCH_DEPTH=basic
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_FETCH_LIMIT=3
WEB_SEARCH_TIMEOUT_SECONDS=12
WEB_SEARCH_CACHE_TTL_SECONDS=300
WEB_SEARCH_RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Weather
WEATHER_DEFAULT_COUNTRY_CODE=GB
WEATHER_FORECAST_DAYS=5
WEATHER_TIMEOUT_SECONDS=12
WEATHER_CACHE_TTL_SECONDS=900
WEATHER_RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Events
EVENT_SEARCH_PROVIDER=ticketmaster
EVENT_SEARCH_COUNTRY_CODE=GB
EVENT_SEARCH_TIMEOUT_SECONDS=12
TICKETMASTER_API_KEY=
EVENT_SEARCH_CACHE_TTL_SECONDS=600
EVENT_SEARCH_RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Recipes
RECIPE_SEARCH_PROVIDER=themealdb
RECIPE_SEARCH_TIMEOUT_SECONDS=12
RECIPE_SEARCH_CACHE_TTL_SECONDS=1800
RECIPE_SEARCH_RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Resilience
EXTERNAL_API_RETRY_ATTEMPTS=3
EXTERNAL_API_RETRY_BASE_DELAY_SECONDS=0.25
EXTERNAL_API_RETRY_MAX_DELAY_SECONDS=2.0
EXTERNAL_RATE_LIMIT_WINDOW_SECONDS=60
ENABLE_SHARED_RESILIENCE_REDIS=false
