# Docker-local defaults
APP_ENV=docker
ENVIRONMENT=local
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Internal stack services
DATABASE_URL=postgresql+asyncpg://familyops:familyops@postgres:5432/familyops
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
ENABLE_SHARED_RESILIENCE_REDIS=true

# Optional app secrets and API keys
SECRET_KEY=dev-secret-key-change-in-production
API_BEARER_TOKEN=
OPENAI_API_KEY=
GOOGLE_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
